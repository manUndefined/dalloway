<div class="container">
  <section class="history-section">
    <div class="history-header">
      <div class="history-header-text">
        <h1 class="history-title">Historique des entretiens</h1>
        <p class="history-subtitle"><%= @chats.size %> session<%= @chats.size > 1 ? "s" : "" %> d'entraînement</p>
      </div>
    </div>

    <% if @chats.present? %>
      <div class="history-list">
        <% @chats.each do |chat| %>
          <div class="history-card-wrapper">
            <%= link_to chat_path(chat), class: "history-card" do %>
              <div class="history-card-left">
                <div class="history-card-icon">
                  <i class="fa-solid fa-comments"></i>
                </div>
                <div class="history-card-info">
                  <h3 class="history-card-title"><%= chat.offer.title %></h3>
                  <p class="history-card-offer">
                    <% if chat.offer.city.present? %>
                      <%= chat.offer.city %>
                    <% end %>
                  </p>
                  <div class="history-card-meta">
                    <span><i class="fa-regular fa-message"></i> <%= chat.messages.size %> messages</span>
                    <span><i class="fa-regular fa-clock"></i> <%= time_ago_in_words(chat.created_at) %></span>
                  </div>
                </div>
              </div>
              <div class="history-card-right">
                <% last_msg = chat.messages.last %>
                <% if last_msg %>
                  <p class="history-card-preview"><%= truncate(last_msg.content, length: 80) %></p>
                <% end %>
                <span class="history-card-arrow"><i class="fa-solid fa-chevron-right"></i></span>
              </div>
            <% end %>
          </div>
        <% end %>
      </div>

    <% else %>
      <div class="history-empty">
        <div class="history-empty-icon">
          <i class="fa-solid fa-comments"></i>
        </div>
        <p>Aucun entretien pour le moment</p>
        <span>Lancez votre premier entretien depuis une offre d'emploi</span>
        <%= link_to root_path, class: "history-empty-btn" do %>
          <i class="fa-solid fa-arrow-left"></i> Voir les offres
        <% end %>
      </div>
    <% end %>
  </section>
</div>

<% if @chats.present? %>
  <% @chats.each do |chat| %>
    <div class="modal fade" id="deleteChatModal<%= chat.id %>" tabindex="-1" aria-hidden="true">
      <div class="modal-dialog modal-dialog-centered modal-sm">
        <div class="modal-content offer-modal-content">
          <div class="modal-header offer-modal-header">
            <h5 class="modal-title">Supprimer l'entretien</h5>
            <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
          </div>
          <div class="modal-body text-center">
            <div class="delete-modal-icon">
              <i class="fa-solid fa-triangle-exclamation"></i>
            </div>
            <p class="delete-modal-text">Supprimer <strong><%= chat.title %></strong> ?</p>
            <p class="delete-modal-sub">L'historique des messages sera perdu.</p>
          </div>
          <div class="modal-footer justify-content-center">
            <button type="button" class="job-btn job-btn-outline" data-bs-dismiss="modal">Annuler</button>
            <%= button_to chat_path(chat), method: :delete, class: "job-btn job-btn-danger", data: { turbo: false } do %>
              <i class="fa-solid fa-trash"></i> Supprimer
            <% end %>
          </div>
        </div>
      </div>
    </div>
  <% end %>
<% end %>
