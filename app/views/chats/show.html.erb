<div class="container" data-controller="chat">
  <section class="chat-section">
    <div class="chat-header">
      <%= link_to chats_path, class: "chat-back" do %>
        <i class="fa-solid fa-arrow-left"></i> Historique
      <% end %>

      <div class="chat-header-info">
        <h1 class="chat-header-title"><%= @chat.title %></h1>
        <p class="chat-header-offer">
          <i class="fa-solid fa-briefcase"></i> <%= @chat.offer.title %>
          <% if @chat.offer.city.present? %>
            &bull; <%= @chat.offer.city %>
          <% end %>
          &bull; <%= time_ago_in_words(@chat.created_at) %>
        </p>
      </div>
    </div>

    <div class="chat-messages" id="messages" data-chat-target="messages">
      <%= render @chat.messages.order(:created_at) %>
    </div>

    <div class="chat-bubble chat-bubble-assistant d-none" data-chat-target="typing">
      <div class="chat-bubble-avatar">
        <i class="fa-solid fa-robot"></i>
      </div>

      <div class="chat-bubble-content">
        <div class="chat-bubble-role">Dalloway IA</div>
        <div class="chat-bubble-text">Dalloway écrit...</div>
      </div>
    </div>
  </section>
</div>

<div class="chat-form">
  <%= form_with model: [@chat, @message],
                id: "new_message",
                data: {
                  chat_target: "form",
                  action: "turbo:submit-start->chat#submitting turbo:submit-end->chat#submitted"
                } do |f| %>
    <div class="chat-form-group">
      <%= f.text_area :content,
                      rows: 4,
                      placeholder: "Écrivez votre réponse à Dalloway...",
                      class: "chat-input" %>
    </div>

    <div class="chat-form-actions">
      <%= f.submit "Envoyer",
                   class: "btn btn-primary",
                   data: { chat_target: "submit" } %>
    </div>
  <% end %>
</div>
