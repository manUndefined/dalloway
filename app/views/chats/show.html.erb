<div class="chat-page" data-controller="chat">
  <div class="chat-shell">
    <div class="chat-header">
      <%= link_to offer_path(@chat.offer), class: "chat-back", data: { turbo: false } do %>
        <i class="fa-solid fa-arrow-left"></i> Retour à l'offre
      <% end %>

      <div class="chat-header-info">
        <h1 class="chat-header-title"><%= @chat.title %></h1>
        <p class="chat-header-offer">
          <%= @chat.offer.title %>
          <% if @chat.offer.city.present? %>
            &bull; <%= @chat.offer.city %>
          <% end %>
          &bull; <%= time_ago_in_words(@chat.created_at) %>
        </p>
      </div>
    </div>

    <div class="chat-messages" id="messages" data-chat-target="messages">
      <%= render @chat.messages.order(:created_at) %>
     
    </div>
    <div class="chat-form-wrapper">
      <%= form_with model: [@chat, @message],
                    id: "new_message",
                    class: "chat-form",
                    data: {
                      chat_target: "form",
                      action: "turbo:submit-start->chat#submitting turbo:submit-end->chat#submitted"
                    } do |f| %>
        <div class="chat-input-wrap">
          <%= f.text_area :content,
                          rows: 1,
                          placeholder: "Écrivez votre réponse...",
                          class: "chat-input" %>
          <button type="submit" class="chat-send-btn" data-chat-target="submit">
            <i class="fa-solid fa-paper-plane"></i>
          </button>
        </div>
      <% end %>
    </div>
  </div>
</div>
