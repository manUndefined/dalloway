<h1><%= @offer.title %></h1>

<p><strong>Description :</strong></p>
<p><%= @offer.description %></p>

<p><strong>URL :</strong> <%= link_to "Voir l'offre", @offer.url, target: "_blank" %></p>

<p><strong>Créé le :</strong> <%= @offer.created_at.strftime("%d %B %Y") %></p>

<%= link_to "Retour à la liste", offers_path %>

<hr>

<h2>Générer une lettre de motivation</h2>

<%= form_with url: generate_cover_letter_offer_path(@offer), method: :post, local: true do |f| %>

  <div>
    <%= label_tag :name, "Votre nom" %><br>
    <%= text_field_tag :name %>
  </div>

  <div>
    <%= label_tag :skills, "Vos compétences principales" %><br>
    <%= text_field_tag :skills %>
  </div>

  <div>
    <%= label_tag :experience, "Votre expérience" %><br>
    <%= text_area_tag :experience %>
  </div>

  <br>

  <%= submit_tag "Générer la lettre" %>

<% end %>
