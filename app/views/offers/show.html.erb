<div class="offer-show">

  <!-- HEADER -->
  <div class="offer-show-header">
    <div class="offer-show-header-top">
      <%= link_to root_path, class: "offer-show-back" do %>
        <i class="fa-solid fa-arrow-left"></i> Retour aux offres
      <% end %>
      <%= link_to offer_chats_path(@offer),
                  data: { turbo_method: :post },
                  class: "offer-show-session-btn" do %>
        <i class="fa-solid fa-bullseye"></i> Nouvelle session d'entraînement
      <% end %>
    </div>

    <a href="<%= @offer.url %>" target="_blank" class="apply-btn">Postuler</a>
  </div>

  
  <div class="job-layout">

    <div class="job-content">

      <section class="job-section">
    
      <span class="label">Description du poste</span>
      <div class="offer-description-content"><%= simple_format(@offer.description) %></div>
      <aside class="job-sidebar">

    <div class="offer-show-badges">
      <% if @offer.city.present? %>
        <span class="offer-show-badge"><i class="fa-solid fa-location-dot"></i> <%= @offer.city %></span>
      <% end %>
      <% if @offer.job_type.present? %>
        <span class="offer-show-badge"><i class="fa-solid fa-file-contract"></i> <%= @offer.job_type %></span>
      <% end %>
      <% if @offer.salary.present? %>
        <span class="offer-show-badge offer-show-badge-salary"><i class="fa-solid fa-euro-sign"></i> <%= number_to_currency(@offer.salary, unit: "€", format: "%n %u", precision: 0) %></span>
      <% end %>
      <% if @offer.experience_level.present? %>
        <span class="offer-show-badge"><i class="fa-solid fa-chart-simple"></i> <%= @offer.experience_level %></span>
      <% end %>
      <% if @offer.domain.present? %>
        <span class="offer-show-badge"><i class="fa-solid fa-layer-group"></i> <%= @offer.domain %></span>
      <% end %>
    </div>

      <div class="info-card">

        <h3>Informations</h3>
        <div class="info-row">
          <span>📍 Localisation</span>
          <strong><%= @offer.city %></strong>
        </div>
        <div class="info-row">
          <span>💼 Contrat</span>
          <strong><%= @offer.job_type %></strong>
        </div>
        <div class="info-row">
          <span>💰 Salaire</span>
          <strong><%= @offer.salary %>k€</strong>
        </div>
      <% end %>

      <!-- LETTRE DE MOTIVATION -->
      <div class="offer-show-card">
        <h2 class="offer-show-section-title"><i class="fa-solid fa-envelope-open-text"></i> Lettre de motivation</h2>

        <% if @offer.cover_letters.any? %>
          <%= form_with model: [@offer.cover_letters.last], local: true do |f| %>
            <div class="offer-show-field">
              <label class="offer-show-label">Contenu</label>
              <%= f.text_area :content, class: "offer-show-textarea" %>
            </div>
            <div class="offer-show-field">
              <label class="offer-show-label">Des précisions</label>
              <%= f.text_area :details, class: "offer-show-textarea", rows: 3 %>
            </div>
            <%= f.submit "Mettre à jour la lettre", class: "offer-show-btn-primary" %>
          <% end %>

          <%= form_with model: [@offer, @cover_letter], local: true do |f| %>
            <%= f.submit "Regénérer la lettre", class: "offer-show-btn-secondary" %>
          <% end %>

        <% else %>
          <%= form_with model: [@offer, @cover_letter], local: true do |f| %>
            <div class="offer-show-field">
              <label class="offer-show-label">Des précisions</label>
              <%= f.text_area :details, class: "offer-show-textarea", rows: 3, placeholder: "Ex: je suis spécialisé en Ruby on Rails avec 3 ans d'expérience..." %>
            </div>
            <%= f.submit "Générer la lettre", class: "offer-show-btn-primary" %>
          <% end %>
        <% end %>

        <% if @letter.present? %>
          <div class="offer-show-letter-result">
            <%= simple_format(@letter) %>
          </div>
        <% end %>
      </div>
    </div>

    <!-- SIDEBAR -->
    <aside class="offer-show-sidebar">
      <div class="offer-show-card">
        <h3 class="offer-show-sidebar-title">Informations</h3>
        <% if @offer.city.present? %>
          <div class="offer-show-info-row">
            <span class="offer-show-info-label"><i class="fa-solid fa-location-dot"></i> Localisation</span>
            <strong><%= @offer.city %></strong>
          </div>
        <% end %>
        <% if @offer.job_type.present? %>
          <div class="offer-show-info-row">
            <span class="offer-show-info-label"><i class="fa-solid fa-file-contract"></i> Contrat</span>
            <strong><%= @offer.job_type %></strong>
          </div>
        <% end %>
        <% if @offer.salary.present? %>
          <div class="offer-show-info-row">
            <span class="offer-show-info-label"><i class="fa-solid fa-euro-sign"></i> Salaire</span>
            <strong><%= number_to_currency(@offer.salary, unit: "€", format: "%n %u", precision: 0) %></strong>
          </div>
        <% end %>
        <% if @offer.experience_level.present? %>
          <div class="offer-show-info-row">
            <span class="offer-show-info-label"><i class="fa-solid fa-chart-simple"></i> Expérience</span>
            <strong><%= @offer.experience_level %></strong>
          </div>
        <% end %>
        <% if @offer.domain.present? %>
          <div class="offer-show-info-row">
            <span class="offer-show-info-label"><i class="fa-solid fa-layer-group"></i> Domaine</span>
            <strong><%= @offer.domain %></strong>
          </div>
        <% end %>
      </div>

      <% if @offer.url.present? %>
        <div class="offer-show-card offer-show-card-cta">
          <p class="offer-show-cta-text">Cette offre vous intéresse ?</p>
          <a href="<%= @offer.url %>" target="_blank" class="offer-show-btn-primary offer-show-btn-block">
            <i class="fa-solid fa-external-link"></i> Postuler
          </a>
          <%= link_to offer_chats_path(@offer),
                      data: { turbo_method: :post },
                      class: "offer-show-btn-secondary offer-show-btn-block" do %>
            <i class="fa-solid fa-bullseye"></i> S'entraîner avec l'IA
          <% end %>
        </div>
      <% end %>
    </aside>

  </div>
</div>
