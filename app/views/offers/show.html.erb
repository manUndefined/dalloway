<div class="job-container">

  <button class="btn-session">
    <span class="btn-icon">🎯</span>
    Nouvelle session d'entraînement
  </button>

  <div class="job-header">
    <h1><%= @offer.title %></h1>

    <div class="job-meta">
      <span class="badge">📍<%= @offer.city %></span>
      <span class="badge">💼 <%= @offer.job_type %></span>
      <span class="badge salary">💰 <%= @offer.salary %>k€</span>
    </div>

    <a href="<%= @offer.url %>" target="_blank" class="apply-btn">Postuler</a>
  </div>

  
  <div class="job-layout">

    <div class="job-content">

      <section class="job-section">
        <h2>Description du poste</h2>
        <p>
          Nous recherchons un développeur web pour rejoindre notre équipe et
          participer à la création d'applications modernes.
        </p>
      </section>

      <section class="job-section">
        <h2>Missions</h2>
        <ul>
          <li>Développer des applications web</li>
          <li>Collaborer avec l'équipe produit</li>
          <li>Maintenir les services existants</li>
        </ul>
      </section>

      <section class="job-section">
        <h2>Profil recherché</h2>
        <ul>
          <li>Maîtrise HTML / CSS / JS</li>
          <li>Expérience en développement web</li>
          <li>Esprit d'équipe</li>
        </ul>
      </section>

    </div>


    <span class="label">Description</span>
    <div class="offer-description-content"><%= simple_format(@offer.description) %></div>
    <aside class="job-sidebar">

      <div class="info-card">

        <h3>Informations</h3>
        <div class="info-row">
          <span>📍 Localisation</span>
          <strong><%= @offer.city %></strong>
        </div>
        <div class="info-row">
          <span>💼 Contrat</span>
          <strong><%= @offer.job_type %></strong>
        </div>
        <div class="info-row">
          <span>💰 Salaire</span>
          <strong><%= @offer.salary %>k€</strong>
        </div>

      </div>

    </aside>

  </div>

</div>


  <!-- CARD LETTRE -->

<div class="letter-container">
  <div class="letter-section">
    <h2>Générer une lettre de motivation</h2>

    <% if @offer.cover_letters.any? %>
      <%= form_with model: [@offer.cover_letters.last], local: true do |f| %>
        <span class="label">Contenu</span>
        <%= f.text_area :content %>

        <span class="label" style="margin-top:16px;">Des précisions</span>
        <%= f.text_area :details %>

        <%= f.submit "Mettre à jour la lettre", class: "btn-full" %>
      <% end %>

      <%= form_with model: [@offer, @cover_letter], local: true do |f| %>
        <%= f.submit "Regénérer la lettre", class: "btn-full", style: "background:#475569;" %>
      <% end %>

    <% else %>
      <%= form_with model: [@offer, @cover_letter], local: true do |f| %>
        <span class="label">Des précisions</span>
        <%= f.text_area :details %>
        <%= f.submit "Générer la lettre", class: "btn-full" %>
      <% end %>
    <% end %>

    <% if @letter.present? %>
      <div class="generated-letter">
        <%= simple_format(@letter) %>
      </div>
    <% end %>

  </div>
</div>
