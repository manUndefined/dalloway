<div class="offer-show">
  <!-- HEADER -->
  <div class="offer-show-header">
    <div class="offer-show-header-top">
      <%= link_to root_path, class: "offer-show-back" do %>
        <i class="fa-solid fa-arrow-left"></i> Retour aux offres
      <% end %>

      <%= link_to offer_chats_path(@offer),
                  data: { turbo_method: :post },
                  class: "offer-show-session-btn" do %>
        <i class="fa-solid fa-robot"></i> S'entraîner avec l'IA
      <% end %>
    </div>

    <h1 class="offer-show-title"><%= @offer.title %></h1>

    <div class="offer-show-badges">
      <% if @offer.city.present? %>
        <span class="offer-show-badge">
          <i class="fa-solid fa-location-dot"></i> <%= @offer.city %>
        </span>
      <% end %>

      <% if @offer.job_type.present? %>
        <span class="offer-show-badge">
          <i class="fa-solid fa-file-contract"></i> <%= @offer.job_type %>
        </span>
      <% end %>

      <% if @offer.salary.present? %>
        <span class="offer-show-badge offer-show-badge-salary">
          <i class="fa-solid fa-euro-sign"></i>
          <%= number_to_currency(@offer.salary, unit: "€", format: "%n %u", precision: 0) %>
        </span>
      <% end %>

      <% if @offer.experience_level.present? %>
        <span class="offer-show-badge">
          <i class="fa-solid fa-chart-simple"></i> <%= @offer.experience_level %>
        </span>
      <% end %>

      <% if @offer.domain.present? %>
        <span class="offer-show-badge">
          <i class="fa-solid fa-layer-group"></i> <%= @offer.domain %>
        </span>
      <% end %>
    </div>
  </div>

  <!-- LAYOUT 2 COLONNES -->
  <div class="offer-show-layout">

    <!-- COLONNE PRINCIPALE -->
    <div class="offer-show-main">
      <% if @offer.description.present? %>
        <div class="offer-show-card">
          <h2 class="offer-show-section-title">
            <i class="fa-solid fa-align-left"></i> Description du poste
          </h2>

          <div class="offer-show-description">
            <%= simple_format(@offer.description) %>
          </div>
        </div>
      <% end %>

      <!-- LETTRE DE MOTIVATION -->
      <div class="offer-show-card">
        <h2 class="offer-show-section-title">
          <i class="fa-solid fa-envelope-open-text"></i> Lettre de motivation
        </h2>

      <%= render "cover_letters/section", offer: @offer, cover_letter: @cover_letter %>
        
      </div>
    </div>

    <!-- SIDEBAR -->
    <aside class="offer-show-sidebar">
      <div class="offer-show-card">
        <h3 class="offer-show-sidebar-title">Informations</h3>

        <% if @offer.city.present? %>
          <div class="offer-show-info-row">
            <span class="offer-show-info-label">
              <i class="fa-solid fa-location-dot"></i> Localisation
            </span>
            <strong><%= @offer.city %></strong>
          </div>
        <% end %>

        <% if @offer.job_type.present? %>
          <div class="offer-show-info-row">
            <span class="offer-show-info-label">
              <i class="fa-solid fa-file-contract"></i> Contrat
            </span>
            <strong><%= @offer.job_type %></strong>
          </div>
        <% end %>

        <% if @offer.salary.present? %>
          <div class="offer-show-info-row">
            <span class="offer-show-info-label">
              <i class="fa-solid fa-euro-sign"></i> Salaire
            </span>
            <strong><%= number_to_currency(@offer.salary, unit: "€", format: "%n %u", precision: 0) %></strong>
          </div>
        <% end %>

        <% if @offer.experience_level.present? %>
          <div class="offer-show-info-row">
            <span class="offer-show-info-label">
              <i class="fa-solid fa-chart-simple"></i> Expérience
            </span>
            <strong><%= @offer.experience_level %></strong>
          </div>
        <% end %>

        <% if @offer.domain.present? %>
          <div class="offer-show-info-row">
            <span class="offer-show-info-label">
              <i class="fa-solid fa-layer-group"></i> Domaine
            </span>
            <strong><%= @offer.domain %></strong>
          </div>
        <% end %>
        <% if @offer.url.present? %>  
         <a href="<%= @offer.url %>" target="_blank" class="offer-show-btn-primary offer-show-btn-block mt-2">
            <i class="fa-solid fa-external-link"></i> Postuler
          </a>
        <% end %>
      </div>

      
    </aside>
  </div>
</div>
