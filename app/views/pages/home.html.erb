<!-- HERO -->
<section class="hero">
  <div class="hero-bg">
    <div class="hero-glow hero-glow-1"></div>
    <div class="hero-glow hero-glow-2"></div>
  </div>
  <div class="container">
    <div class="hero-content">
      <span class="hero-badge">
        <i class="fa-solid fa-wand-magic-sparkles"></i> Propulsé par l'IA
      </span>
      <h1 class="hero-title">Décrochez votre prochain job<br><span class="hero-highlight">en quelques clics</span></h1>
      <p class="hero-desc">Entraînez-vous aux entretiens avec une IA qui s'adapte à votre CV et à l'offre ciblée.</p>
    </div>
  </div>
</section>

<!-- STATS -->
<section class="stats-section">
  <div class="container">
    <div class="stats-grid">
      <div class="stat-card">
        <div class="stat-icon"><i class="fa-solid fa-briefcase"></i></div>
        <div class="stat-number"><%= @stats[:offers] %></div>
        <div class="stat-label">Offres sauvegardées</div>
      </div>
      <div class="stat-card">
        <div class="stat-icon"><i class="fa-solid fa-comments"></i></div>
        <div class="stat-number"><%= @stats[:interviews] %></div>
        <div class="stat-label">Entretiens réalisés</div>
      </div>
      <div class="stat-card">
        <div class="stat-icon"><i class="fa-solid fa-users"></i></div>
        <div class="stat-number"><%= @stats[:users] %></div>
        <div class="stat-label">Utilisateurs actifs</div>
      </div>
    </div>
  </div>
</section>

<!-- COMMENT CA MARCHE -->
<section class="how-section">
  <div class="container">
    <div class="how-header">
      <h2 class="how-title">Comment ça marche ?</h2>
      <p class="how-subtitle">Préparez vos entretiens en 3 étapes simples</p>
    </div>
    <div class="how-grid">
      <div class="how-step">
        <div class="how-step-number">1</div>
        <div class="how-step-icon"><i class="fa-solid fa-link"></i></div>
        <h3 class="how-step-title">Collez un lien d'offre</h3>
        <p class="how-step-desc">Copiez l'URL d'une offre depuis HelloWork, Indeed ou LinkedIn. Les champs se remplissent automatiquement.</p>
      </div>
      <div class="how-connector"><i class="fa-solid fa-arrow-right"></i></div>
      <div class="how-step">
        <div class="how-step-number">2</div>
        <div class="how-step-icon"><i class="fa-solid fa-robot"></i></div>
        <h3 class="how-step-title">Lancez l'entretien IA</h3>
        <p class="how-step-desc">Notre IA analyse l'offre et simule un entretien réaliste adapté au poste et à votre profil.</p>
      </div>
      <div class="how-connector"><i class="fa-solid fa-arrow-right"></i></div>
      <div class="how-step">
        <div class="how-step-number">3</div>
        <div class="how-step-icon"><i class="fa-solid fa-chart-line"></i></div>
        <h3 class="how-step-title">Progressez</h3>
        <p class="how-step-desc">Recevez un feedback détaillé, identifiez vos points forts et axes d'amélioration.</p>
      </div>
    </div>
  </div>
</section>

<!-- CTA SECTION -->
<section class="cta-section">
  <div class="container">
    <div class="cta-content">
      <h2 class="cta-title">Prêt à vous lancer ?</h2>
      <p class="cta-desc">Ajoutez une offre ou explorez celles disponibles pour commencer votre entraînement.</p>
      <div class="cta-actions">
        <button class="hero-cta hero-cta-primary" data-bs-toggle="modal" data-bs-target="#addOfferModal">
          <i class="fa-solid fa-plus"></i> Ajouter une offre
        </button>
        <a href="#offres" class="hero-cta hero-cta-secondary">
          <i class="fa-solid fa-magnifying-glass"></i> Explorer les offres
        </a>
      </div>
    </div>
  </div>
</section>

<div class="container">
  <!-- ADD OFFER MODAL -->
  <div class="modal fade" id="addOfferModal" tabindex="-1" aria-labelledby="addOfferModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-centered">
      <div class="modal-content offer-modal-content">
        <div class="modal-header offer-modal-header">
          <div class="offer-form-header mb-0">
            <div class="offer-form-icon">
              <i class="fa-solid fa-plus"></i>
            </div>
            <div>
              <h2 class="offer-form-title" id="addOfferModalLabel">Nouvelle offre</h2>
              <p class="offer-form-subtitle">Renseignez les détails de l'offre puis lancez un entretien avec l'IA</p>
            </div>
          </div>
          <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
        </div>
        <div class="modal-body">
          <%= form_with model: Offer.new, url: offers_path, method: :post, class: "offer-form", data: { controller: "scraper" } do |f| %>
            <div class="offer-form-grid">
              <div class="offer-field offer-field-full">
                <label class="offer-label">
                  <i class="fa-solid fa-link"></i> URL de l'offre
                </label>
                <div class="offer-url-wrap">
                  <%= f.text_field :url, placeholder: "https://fr.indeed.com/viewjob?jk=...", class: "offer-input", data: { scraper_target: "url", action: "paste->scraper#paste input->scraper#inputChanged" } %>
                  <div class="offer-url-spinner" data-scraper-target="spinner">
                    <i class="fa-solid fa-spinner fa-spin"></i>
                  </div>
                </div>
              </div>

              <div class="offer-field">
                <label class="offer-label">
                  <i class="fa-solid fa-briefcase"></i> Poste
                </label>
                <%= f.text_field :title, placeholder: "Développeur Ruby on Rails", class: "offer-input", data: { scraper_target: "title" } %>
              </div>

              <div class="offer-field">
                <label class="offer-label">
                  <i class="fa-solid fa-location-dot"></i> Ville
                </label>
                <%= f.text_field :city, placeholder: "Paris", class: "offer-input", data: { scraper_target: "city" } %>
              </div>

              <div class="offer-field">
                <label class="offer-label">
                  <i class="fa-solid fa-layer-group"></i> Domaine
                </label>
                <%= f.text_field :domain, placeholder: "Web development", class: "offer-input", data: { scraper_target: "domain" } %>
              </div>

              <div class="offer-field">
                <label class="offer-label">
                  <i class="fa-solid fa-euro-sign"></i> Salaire
                </label>
                <%= f.number_field :salary, placeholder: "45000", class: "offer-input", data: { scraper_target: "salary" } %>
              </div>

              <div class="offer-field">
                <label class="offer-label">
                  <i class="fa-solid fa-tag"></i> Type de contrat
                </label>
                <%= f.select :job_type, options_for_select(["CDI", "CDD", "Freelance", "Stage", "Alternance"]), { include_blank: "Sélectionner..." }, class: "offer-input", data: { scraper_target: "jobType" } %>
              </div>

              <div class="offer-field">
                <label class="offer-label">
                  <i class="fa-solid fa-chart-line"></i> Niveau d'expérience
                </label>
                <%= f.select :experience_level, options_for_select(["Junior", "Intermédiaire", "Senior"]), { include_blank: "Sélectionner..." }, class: "offer-input", data: { scraper_target: "experienceLevel" } %>
              </div>

              <div class="offer-field offer-field-full">
                <label class="offer-label">
                  <i class="fa-solid fa-align-left"></i> Description
                </label>
                <%= f.text_area :description, placeholder: "Description du poste...", class: "offer-input offer-textarea", rows: 3, data: { scraper_target: "description" } %>
              </div>
            </div>

            <div class="offer-form-actions">
              <%= f.submit "Ajouter l'offre", class: "offer-btn offer-btn-secondary" %>
              <%= f.submit "Lancer la session", class: "offer-btn offer-btn-primary" %>
            </div>
          <% end %>
        </div>
      </div>
    </div>
  </div>

  <!-- HELLOWORK OFFERS -->
  <section class="jobs-section" id="offres">
    <div class="jobs-header">
      <h2 class="jobs-title">Offres du moment</h2>
      <p class="jobs-subtitle">
        <% if user_signed_in? && (current_user.preferred_sector.present? || current_user.preferred_city.present?) %>
          Offres HelloWork filtrées selon vos préférences
        <% else %>
          Dernières offres disponibles sur HelloWork
        <% end %>
      </p>
    </div>

    <!-- SEARCH BAR -->
    <%= form_with url: root_path, method: :get, class: "search-bar" do |f| %>
      <div class="search-fields">
        <div class="search-field">
          <i class="fa-solid fa-magnifying-glass"></i>
          <%= f.text_field :keyword, value: @search_keyword, placeholder: "Métier, technologie...", class: "search-input" %>
        </div>
        <div class="search-field">
          <i class="fa-solid fa-location-dot"></i>
          <%= f.text_field :city, value: @search_city, placeholder: "Ville", class: "search-input" %>
        </div>
      </div>
      <%= f.submit "Rechercher", class: "search-btn" %>
    <% end %>

    <% if @hellowork_offers.present? %>
      <div class="jobs-grid">
        <% @hellowork_offers.each do |hw| %>
          <div class="job-card">
            <div class="job-card-top">
              <div class="job-card-icon">
                <i class="fa-solid fa-briefcase"></i>
              </div>
              <h3 class="job-card-title"><%= hw[:title] %></h3>
              <% if hw[:company].present? %>
                <p class="job-card-company"><i class="fa-solid fa-building"></i> <%= hw[:company] %></p>
              <% end %>
              <div class="job-card-tags">
                <% if hw[:city].present? %>
                  <span class="job-tag"><i class="fa-solid fa-location-dot"></i> <%= hw[:city] %></span>
                <% end %>
                <% if hw[:job_type].present? %>
                  <span class="job-tag"><i class="fa-solid fa-tag"></i> <%= hw[:job_type] %></span>
                <% end %>
                <% if hw[:salary].present? %>
                  <span class="job-tag"><i class="fa-solid fa-euro-sign"></i> <%= hw[:salary] %></span>
                <% end %>
                <% if hw[:remote].present? %>
                  <span class="job-tag"><i class="fa-solid fa-house-laptop"></i> <%= hw[:remote] %></span>
                <% end %>
                <% if hw[:domain].present? %>
                  <span class="job-tag"><i class="fa-solid fa-layer-group"></i> <%= hw[:domain] %></span>
                <% end %>
              </div>
              <% if hw[:posted_at].present? %>
                <p class="job-card-date"><i class="fa-regular fa-clock"></i> <%= hw[:posted_at] %></p>
              <% end %>
            </div>
            <div class="job-card-actions">
              <%= button_to import_offers_path, method: :post, params: { url: hw[:url], title: hw[:title], city: hw[:city], domain: hw[:domain], job_type: hw[:job_type] }, class: "job-btn job-btn-outline" do %>
                <i class="fa-solid fa-eye"></i> Voir l'offre
              <% end %>
            </div>
          </div>
        <% end %>
      </div>
    <% else %>
      <div class="jobs-empty">
        <div class="jobs-empty-icon">
          <i class="fa-solid fa-globe"></i>
        </div>
        <p>Impossible de charger les offres HelloWork pour le moment.</p>
        <span>Réessayez dans quelques instants.</span>
      </div>
    <% end %>
  </section>

  <!-- YOUR OFFERS -->
  <% if @offers.present? %>
    <section class="jobs-section">
      <div class="jobs-header">
        <h2 class="jobs-title">Vos offres sauvegardées</h2>
        <p class="jobs-subtitle">Offres que vous avez ajoutées manuellement</p>
      </div>

      <div class="jobs-grid">
        <% @offers.each do |offer| %>
          <div class="job-card">
            <div class="job-card-top">
              <div class="job-card-icon">
                <i class="fa-solid fa-bookmark"></i>
              </div>
              <h3 class="job-card-title"><%= offer.title %></h3>
              <p class="job-card-desc"><%= truncate(offer.description, length: 120) %></p>
              <div class="job-card-tags">
                <% if offer.city.present? %>
                  <span class="job-tag"><i class="fa-solid fa-location-dot"></i> <%= offer.city %></span>
                <% end %>
                <% if offer.job_type.present? %>
                  <span class="job-tag"><i class="fa-solid fa-tag"></i> <%= offer.job_type %></span>
                <% end %>
                <% if offer.experience_level.present? %>
                  <span class="job-tag"><i class="fa-solid fa-chart-line"></i> <%= offer.experience_level %></span>
                <% end %>
                <% if offer.salary.present? %>
                  <span class="job-tag"><i class="fa-solid fa-euro-sign"></i> <%= number_to_currency(offer.salary, unit: "€", format: "%n %u", precision: 0) %></span>
                <% end %>
              </div>
            </div>
            <div class="job-card-actions">
              <%= link_to offer_path(offer), class: "job-btn job-btn-outline" do %>
                <i class="fa-solid fa-eye"></i> Voir
              <% end %>
              <% if user_signed_in? %>
                <button type="button" class="job-btn job-btn-delete" data-bs-toggle="modal" data-bs-target="#deleteOfferModal<%= offer.id %>">
                  <i class="fa-solid fa-trash"></i>
                </button>
              <% end %>
            </div>
          </div>
        <% end %>
      </div>

      <!-- Modals suppression -->
      <% if user_signed_in? %>
        <% @offers.each do |offer| %>
          <div class="modal fade" id="deleteOfferModal<%= offer.id %>" tabindex="-1" aria-hidden="true">
            <div class="modal-dialog modal-dialog-centered modal-sm">
              <div class="modal-content offer-modal-content">
                <div class="modal-header offer-modal-header">
                  <h5 class="modal-title">Supprimer l'offre</h5>
                  <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body text-center">
                  <div class="delete-modal-icon">
                    <i class="fa-solid fa-triangle-exclamation"></i>
                  </div>
                  <p class="delete-modal-text">Supprimer <strong><%= offer.title %></strong> ?</p>
                  <p class="delete-modal-sub">Cette action est irréversible.</p>
                </div>
                <div class="modal-footer justify-content-center">
                  <button type="button" class="job-btn job-btn-outline" data-bs-dismiss="modal">Annuler</button>
                  <form action="<%= offer_path(offer) %>" method="post">
                    <input type="hidden" name="_method" value="delete">
                    <input type="hidden" name="authenticity_token" value="<%= form_authenticity_token %>">
                    <button type="submit" class="job-btn job-btn-danger">
                      <i class="fa-solid fa-trash"></i> Supprimer
                    </button>
                  </form>
                </div>
              </div>
            </div>
          </div>
        <% end %>
      <% end %>
    </section>
  <% end %>
</div>
