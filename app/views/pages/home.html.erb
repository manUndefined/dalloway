<!-- HERO -->
<section class="hero">
  <div class="hero-bg">
    <div class="hero-glow hero-glow-1"></div>
    <div class="hero-glow hero-glow-2"></div>
    <div class="hero-glow hero-glow-3"></div>
    <div class="hero-grid"></div>
    <div class="hero-particles">
      <span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span>
    </div>
  </div>
  <div class="container">
    <div class="hero-content">
      <span class="hero-badge">
        <span class="hero-badge-dot"></span>
        <i class="fa-solid fa-wand-magic-sparkles"></i> Propulsé par l'IA
      </span>
      <h1 class="hero-title">
        <span class="hero-title-line hero-anim-1">Votre prochain entretien</span>
        <span class="hero-title-line hero-anim-3"><span class="hero-highlight">plus serein</span></span>
      </h1>
      <p class="hero-desc">Entraînez-vous aux entretiens avec une IA qui s'adapte à votre CV et à l'offre ciblée.</p>
       <a href="#offres" class="hero-cta hero-cta-secondary mt-4">
          <i class="fa-solid fa-magnifying-glass"></i> Explorer les offres
        </a>
    </div>
  </div>
</section>

<div class="background-style">

<!-- COMMENT CA MARCHE -->
<section class="how-section-v2">
  <div class="container">
    <div class="how-v2-header">
      <span class="how-v2-badge"><i class="fa-solid fa-bolt"></i> Simple & rapide</span>
      <h2 class="how-v2-title">Comment ça marche ?</h2>
      <p class="how-v2-subtitle">Préparez vos entretiens en 3 étapes</p>
    </div>
    <div class="how-v2-grid">
      <div class="how-v2-card">
        <div class="how-v2-number">1</div>
        <div class="how-v2-icon"><i class="fa-solid fa-plus"></i></div>
        <h3 class="how-v2-card-title">Ajouter une offre</h3>
        <p class="how-v2-card-desc">Copiez l'URL d'une offre, les champs se remplissent automatiquement.</p>
      </div>
      <div class="how-v2-connector">
        <div class="how-v2-connector-line"></div>
        <i class="fa-solid fa-chevron-right"></i>
      </div>
      <div class="how-v2-card">
        <div class="how-v2-number">2</div>
        <div class="how-v2-icon"><i class="fa-solid fa-robot"></i></div>
        <h3 class="how-v2-card-title">Lancez l'entretien IA</h3>
        <p class="how-v2-card-desc">Allez sur l'offre et demandez une session. Notre IA simule un entretien adapté.</p>
      </div>
      <div class="how-v2-connector">
        <div class="how-v2-connector-line"></div>
        <i class="fa-solid fa-chevron-right"></i>
      </div>
      <div class="how-v2-card">
        <div class="how-v2-number">3</div>
        <div class="how-v2-icon"><i class="fa-solid fa-chart-line"></i></div>
        <h3 class="how-v2-card-title">Progressez</h3>
        <p class="how-v2-card-desc">Recevez un feedback détaillé, identifiez vos points forts et axes d'amélioration.</p>
      </div>
    </div>
  </div>
</section>


<div class="container">
  <!-- HELLOWORK OFFERS -->
  <section class="jobs-section" id="offres">
    <div class="jobs-header">
      <h2 class="jobs-title">Offres du moment</h2>
      <p class="jobs-subtitle">
        <% if user_signed_in? && (current_user.preferred_sector.present? || current_user.preferred_city.present?) %>
          Offres HelloWork filtrées selon vos préférences
        <% else %>
          Dernières offres disponibles
        <% end %>
      </p>
    </div>

    <!-- SEARCH BAR -->
    <%= form_with url: root_path, method: :get, class: "search-bar", data: { turbo_frame: "hellowork_offers" } do |f| %>
      <div class="search-fields">
        <div class="search-field">
          <i class="fa-solid fa-magnifying-glass"></i>
          <%= f.text_field :keyword, value: @search_keyword, placeholder: "Métier, technologie...", class: "search-input" %>
        </div>
        <div class="search-field">
          <i class="fa-solid fa-location-dot"></i>
          <%= f.text_field :city, value: @search_city, placeholder: "Ville", class: "search-input" %>
        </div>
        <div class="search-field">
          <i class="fa-solid fa-file-contract"></i>
          <%= f.select :contract, options_for_select(["CDI", "CDD", "Freelance", "Stage", "Alternance", "Intérim"], @search_contract), { include_blank: "Type de contrat" }, class: "search-input" %>
        </div>
      </div>
      <%= f.submit "Rechercher", class: "search-btn" %>
    <% end %>

    <%= turbo_frame_tag "hellowork_offers" do %>
      <% if @hellowork_offers.present? %>
        <div class="jobs-grid">
          <% @hellowork_offers.each do |hw| %>
            <%= button_to import_offers_path, method: :post, params: { url: hw[:url], title: hw[:title], city: hw[:city], domain: hw[:domain], job_type: hw[:job_type] }, class: "job-card job-card-clickable" do %>
              <div class="job-card-top">
                <div class="job-card-icon">
                  <i class="fa-solid fa-briefcase"></i>
                </div>
                <h3 class="job-card-title"><%= hw[:title] %></h3>
                <% if hw[:company].present? %>
                  <p class="job-card-company"><i class="fa-solid fa-building"></i> <%= hw[:company] %></p>
                <% end %>
                <div class="job-card-tags">
                  <% if hw[:city].present? %>
                    <span class="job-tag"><i class="fa-solid fa-location-dot"></i> <%= hw[:city] %></span>
                  <% end %>
                  <% if hw[:job_type].present? %>
                    <span class="job-tag"><i class="fa-solid fa-tag"></i> <%= hw[:job_type] %></span>
                  <% end %>
                  <% if hw[:salary].present? %>
                    <span class="job-tag"><i class="fa-solid fa-euro-sign"></i> <%= hw[:salary] %></span>
                  <% end %>
                  <% if hw[:remote].present? %>
                    <span class="job-tag"><i class="fa-solid fa-house-laptop"></i> <%= hw[:remote] %></span>
                  <% end %>
                  <% if hw[:domain].present? %>
                    <span class="job-tag"><i class="fa-solid fa-layer-group"></i> <%= hw[:domain] %></span>
                  <% end %>
                </div>
                <% if hw[:posted_at].present? %>
                  <p class="job-card-date"><i class="fa-regular fa-clock"></i> <%= hw[:posted_at] %></p>
                <% end %>
              </div>
            <% end %>
          <% end %>
        </div>
      <% else %>
        <div class="jobs-empty">
          <div class="jobs-empty-icon">
            <i class="fa-solid fa-filter-circle-xmark"></i>
          </div>
          <p class="jobs-empty-title">Aucun résultat trouvé</p>
          <p class="jobs-empty-sub">Aucune offre ne correspond à vos critères de recherche.<br>Essayez d'autres mots-clés ou une ville différente.</p>
          <%= link_to root_path, class: "jobs-empty-reset", data: { turbo_frame: "hellowork_offers" } do %>
            <i class="fa-solid fa-rotate-left"></i> Réinitialiser la recherche
          <% end %>
        </div>
      <% end %>
    <% end %>
  </section>

</div>
</div>
