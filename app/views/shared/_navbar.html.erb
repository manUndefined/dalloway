<nav class="navbar navbar-expand-md navbar-dalloway">
  <div class="container">
    <%= link_to root_path, class: "navbar-brand" do %>
      <span class="navbar-logo">D</span>
      <span class="navbar-brand-text">Dalloway</span>
    <% end %>

    <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav" aria-controls="navbarNav" aria-expanded="false" aria-label="Toggle navigation">
      <i class="fa-solid fa-bars"></i>
    </button>

    <div class="collapse navbar-collapse" id="navbarNav">
      <ul class="navbar-nav ms-auto align-items-center">
        <% if user_signed_in? %>
          <li class="nav-item">
            <%= link_to root_path, class: "nav-link" do %>
              <i class="fa-solid fa-house"></i> Accueil
            <% end %>
          </li>
          <li class="nav-item">
            <%= link_to "#", class: "nav-link" do %>
              <i class="fa-solid fa-briefcase"></i> Offres
            <% end %>
          </li>
          <li class="nav-item">
            <%= link_to chats_path, class: "nav-link" do %>
              <i class="fa-solid fa-clock-rotate-left"></i> Historique
            <% end %>
          </li>
          <li class="nav-item dropdown">
            <a href="#" class="nav-link nav-avatar-link" id="navbarDropdown" data-bs-toggle="dropdown" aria-expanded="false">
              <span class="nav-avatar-circle">
                <%= current_user.first_name&.first&.upcase || "U" %>
              </span>
            </a>
            <div class="dropdown-menu dropdown-menu-end nav-dropdown" aria-labelledby="navbarDropdown">
              <div class="nav-dropdown-header">
                <strong><%= current_user.first_name %> <%= current_user.last_name %></strong>
                <span><%= current_user.email %></span>
              </div>
              <div class="dropdown-divider"></div>
              <%= link_to "#", class: "dropdown-item nav-dropdown-item" do %>
                <i class="fa-solid fa-user"></i> Mon profil
              <% end %>
              <div class="dropdown-divider"></div>
              <%= link_to destroy_user_session_path, data: { turbo_method: :delete }, class: "dropdown-item nav-dropdown-item nav-dropdown-logout" do %>
                <i class="fa-solid fa-right-from-bracket"></i> Déconnexion
              <% end %>
            </div>
          </li>
        <% else %>
          <li class="nav-item">
            <%= link_to new_user_session_path, class: "nav-link" do %>
              <i class="fa-solid fa-right-to-bracket"></i> Connexion
            <% end %>
          </li>
          <li class="nav-item">
            <%= link_to new_user_registration_path, class: "nav-btn-signup" do %>
              S'inscrire
            <% end %>
          </li>
        <% end %>
      </ul>
    </div>
  </div>
</nav>
