<div class="container py-5">
  <h1 class="mb-4">Modifier mon profil</h1>

  <div class="card p-4 shadow-sm">
    <%= form_with model: @user, url: profile_path, method: :patch, local: true do |f| %>
      <div class="mb-3">
        <%= f.label :first_name, "Prénom", class: "form-label" %>
        <%= f.text_field :first_name, class: "form-control" %>
      </div>

      <div class="mb-3">
        <%= f.label :last_name, "Nom", class: "form-label" %>
        <%= f.text_field :last_name, class: "form-control" %>
      </div>

      <div class="mb-3">
        <%= f.label :city, "Ville", class: "form-label" %>
        <%= f.text_field :city, class: "form-control" %>
      </div>

      <div class="mb-3">
        <%= f.label :domain, "Domaine", class: "form-label" %>
        <%= f.text_field :domain, class: "form-control" %>
      </div>

      <div class="mb-3">
        <%= f.label :job_type, "Type de job", class: "form-label" %>
        <%= f.text_field :job_type, class: "form-control" %>
      </div>

      <div class="mb-3">
        <%= f.label :experience_level, "Niveau d'expérience", class: "form-label" %>
        <%= f.text_field :experience_level, class: "form-control" %>
      </div>

      <div class="mb-3">
        <%= f.label :salary, "Salaire visé", class: "form-label" %>
        <%= f.number_field :salary, class: "form-control" %>
      </div>

      <div class="d-flex gap-2">
        <%= f.submit "Enregistrer", class: "btn btn-primary" %>
        <%= link_to "Annuler", profile_path, class: "btn btn-secondary" %>
      </div>
    <% end %>
  </div>
</div>
