<div class="container py-5">
  <div class="profile-header">
    <h1 class="profile-page-title">Mon profil</h1>
    <p class="profile-page-subtitle">Gérez vos informations personnelles et vos préférences de recherche</p>
  </div>

  <div class="profile-grid">
    <!-- CARD AVATAR -->
    <div class="profile-card profile-card-avatar">
      <div class="profile-avatar-wrap">
        <% if @user.photo.attached? %>
          <%= image_tag @user.photo, class: "profile-avatar-img" %>
        <% else %>
          <div class="profile-avatar-placeholder">
            <i class="fa-solid fa-user"></i>
          </div>
        <% end %>
      </div>
      <h3 class="profile-name">
        <%= [@user.first_name, @user.last_name].compact.join(" ").presence || "Nom non renseigné" %>
      </h3>
      <p class="profile-email"><%= @user.email %></p>
      <% if @user.cv.attached? %>
        <%= link_to url_for(@user.cv), target: "_blank", class: "profile-cv-btn" do %>
          <i class="fa-solid fa-file-pdf"></i> Voir mon CV
        <% end %>
      <% else %>
        <p class="profile-no-cv"><i class="fa-solid fa-file-circle-xmark"></i> Aucun CV ajouté</p>
      <% end %>
    </div>

    <!-- CARD INFOS -->
    <div class="profile-card profile-card-infos">
      <div class="profile-infos-header">
        <div>
          <h4 class="profile-infos-title">Préférences professionnelles</h4>
          <p class="profile-infos-subtitle">Ces informations aideront Dalloway à personnaliser votre expérience</p>
        </div>
        <%= link_to edit_profile_path, class: "profile-edit-btn" do %>
          <i class="fa-solid fa-pen"></i> Modifier
        <% end %>
      </div>

      <div class="profile-fields-grid">
        <div class="profile-field">
          <span class="profile-field-label"><i class="fa-solid fa-user"></i> Prénom</span>
          <span class="profile-field-value"><%= @user.first_name.presence || "Non renseigné" %></span>
        </div>

        <div class="profile-field">
          <span class="profile-field-label"><i class="fa-solid fa-user-tag"></i> Nom</span>
          <span class="profile-field-value"><%= @user.last_name.presence || "Non renseigné" %></span>
        </div>

        <div class="profile-field">
          <span class="profile-field-label"><i class="fa-solid fa-location-dot"></i> Ville</span>
          <span class="profile-field-value"><%= @user.city.presence || "Non renseignée" %></span>
        </div>

        <div class="profile-field">
          <span class="profile-field-label"><i class="fa-solid fa-layer-group"></i> Domaine</span>
          <span class="profile-field-value"><%= @user.domain.presence || "Non renseigné" %></span>
        </div>

        <div class="profile-field">
          <span class="profile-field-label"><i class="fa-solid fa-tag"></i> Type de job</span>
          <span class="profile-field-value"><%= @user.job_type.presence || "Non renseigné" %></span>
        </div>

        <div class="profile-field">
          <span class="profile-field-label"><i class="fa-solid fa-chart-line"></i> Niveau d'expérience</span>
          <span class="profile-field-value"><%= @user.experience_level.presence || "Non renseigné" %></span>
        </div>

        <div class="profile-field profile-field-full">
          <span class="profile-field-label"><i class="fa-solid fa-euro-sign"></i> Salaire visé</span>
          <span class="profile-field-value"><%= @user.salary.present? ? "#{@user.salary} €" : "Non renseigné" %></span>
        </div>
      </div>
    </div>
  </div>
</div>
